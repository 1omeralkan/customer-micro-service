<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="20260302-09" author="omeralkan">

        <dropColumn tableName="customer" columnName="adres"/>

        <addColumn tableName="customer">
            <column name="address_country_id" type="BIGINT">
                <constraints nullable="true" foreignKeyName="fk_cust_address_country" referencedTableName="countries" referencedColumnNames="id"/>
            </column>

            <column name="address_city_id" type="BIGINT">
                <constraints nullable="true" foreignKeyName="fk_cust_address_city" referencedTableName="cities" referencedColumnNames="id"/>
            </column>

            <column name="open_address" type="VARCHAR(255)"/>

            <column name="phone_country_id" type="BIGINT">
                <constraints nullable="true" foreignKeyName="fk_cust_phone_country" referencedTableName="countries" referencedColumnNames="id"/>
            </column>

            <column name="phone_number" type="VARCHAR(20)"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260302-10" author="omeralkan">
        <insert tableName="countries">
            <column name="iso_code" value="TR"/>
            <column name="name" value="Türkiye"/>
            <column name="phone_code" value="+90"/>
        </insert>

        <insert tableName="cities">
            <column name="country_id" valueNumeric="1"/>
            <column name="city_code" value="34"/>
            <column name="name" value="İstanbul"/>
        </insert>

        <insert tableName="cities">
            <column name="country_id" valueNumeric="1"/>
            <column name="city_code" value="06"/>
            <column name="name" value="Ankara"/>
        </insert>
    </changeSet>

    <changeSet id="20260303-11" author="omeralkan">
        <dropColumn tableName="customer" columnName="tel_no"/>
    </changeSet>

</databaseChangeLog>