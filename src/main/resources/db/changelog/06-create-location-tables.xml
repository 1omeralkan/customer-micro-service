<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="20260302-07" author="omeralkan">
        <createTable tableName="countries">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="iso_code" type="varchar(5)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="phone_code" type="varchar(10)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20260302-08" author="omeralkan">
        <createTable tableName="cities">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="country_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_cities_country_id"
                             referencedTableName="countries"
                             referencedColumnNames="id"/>
            </column>
            <column name="city_code" type="varchar(10)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="cities" columnNames="country_id, city_code" constraintName="uk_cities_country_city"/>
    </changeSet>

</databaseChangeLog>