<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="20260303-15" author="omeralkan">

        <addColumn tableName="cities">
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="create_user" type="VARCHAR(50)" defaultValue="admin">
                <constraints nullable="false"/>
            </column>
            <column name="update_date" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
            <column name="update_user" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn tableName="countries">
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="create_user" type="VARCHAR(50)" defaultValue="admin">
                <constraints nullable="false"/>
            </column>
            <column name="update_date" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
            <column name="update_user" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addColumn tableName="error_messages">
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="create_user" type="VARCHAR(50)" defaultValue="admin">
                <constraints nullable="false"/>
            </column>
            <column name="update_date" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
            <column name="update_user" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

    </changeSet>

</databaseChangeLog>